---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import IconRss from "@/assets/icons/IconRss.svg";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-8 pb-6 border-b border-border">
      <div class="flex justify-between items-start">
        <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
          Bockman Cheung
        </h1>
        <a
          target="_blank"
          href="/rss.xml"
          class="inline-block mt-8 sm:mt-12"
          aria-label="rss feed"
          title="RSS Feed"
        >
          <IconRss
            width={28}
            height={28}
            class="scale-125 stroke-accent stroke-2 rtl:-rotate-90"
          />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>

      <p class="mb-6 font-medium text-lg">My Academic Homepage</p>

      <p class="mb-6">
        I'm a junior undergraduate at UCLA in the department of mathematics, 
        broadly interested in algebraic geometry and its applications, for example 
        cluster algebras and representation theory. I am also eagerly interested 
        in advancing human-machine interactions to push the frontiers of 
        mathematical research.
      </p>

      <p class="mb-6">My email address is bm[last name]@ucla.edu.</p>

      <div class="mt-8">
        <h2 class="text-lg font-semibold mb-3">Upcoming travels (2026):</h2>
        <ul class="list-disc list-inside space-y-1">
          <li><strong>June 16-20:</strong> 43rd Annual Workshop in Geometric Topology, Salt Lake City, UT</li>
          <li><strong>Aug 16 - Sept 10:</strong> Montréal, QB, Canada</li>
          <li><strong>Sept 10-17:</strong> Boston, MA</li>
          <li><strong>Sept 17-23:</strong> Toronto, OT, Canada</li>
        </ul>
      </div>
    </section>
  </main>
</Layout>
